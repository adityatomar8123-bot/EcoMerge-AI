# EcoMerge ERP runtime environment
POSTGRES_DB=ecomerge
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ecomerge
JWT_SECRET=dev-jwt-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# Optional AI integration
# OPENAI_API_KEY=your_openai_api_key_here
